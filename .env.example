# Florilège — variables d'environnement

# Supabase — persistance (serveur). Requis.
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Supabase — auth par lien magique (navigateur). Requis pour la connexion.
# (mêmes valeurs côté public : l'URL, et la clé "anon"/publishable)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Page admin (/admin) : mot de passe d'accès.
# ADMIN_PASSWORD=
