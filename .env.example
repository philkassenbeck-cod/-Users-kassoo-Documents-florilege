# Florilège — variables d'environnement

# Persistance (Supabase). Sans ces variables, l'app utilise le store mémoire.
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Envoi du lien perso par email (Resend). Sans clé, le lien s'affiche à l'écran.
# RESEND_API_KEY=
# RESEND_FROM=Florilège <florilege@ton-domaine.com>

# Page admin (/admin) : mot de passe d'accès.
# ADMIN_PASSWORD=

# URL publique du site (pour composer les liens dans les emails). Optionnel.
# NEXT_PUBLIC_SITE_URL=https://monflorilege-...vercel.app
